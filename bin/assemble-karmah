#!/bin/env bash

libdir=$(dirname $(dirname $(readlink -f ${BASH_SOURCE[0]})))/lib
prog="${1:-karmah}"

cat $libdir/pre.bash >"$prog"
for lib in  $libdir/*/*.bash; do
    echo adding $lib
    printf '\n#####################################\n# %s\n' $(basename $lib) >>"$prog"
    cat $lib  >>"$prog"
done
printf '\n#####################################\n${prog}-main "${@}"\n' >>"$prog"
chmod 755 "$prog"
